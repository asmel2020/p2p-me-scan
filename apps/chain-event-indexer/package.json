{
  "name": "@chain-event-indexer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "block-stats": "tsx src/local/block-stats.ts",
    "scan": "tsx src/local/scan-blocks.ts",
    "check-blocks": "tsx src/local/check-blocks.ts",
    "reprocess-failed": "tsx src/local/reprocess-failed.ts",
    "fix-timestamps": "tsx src/local/fix-block-timestamps.ts",
    "migrate-timestamps": "tsx src/local/migrate-local-to-d1.ts",
    "rebuild-orders": "tsx src/local/rebuild-orders.ts",
    "migrate-events": "tsx src/local/migrate-scanned-events-to-d1.ts",
    "migrate-orders": "tsx src/local/migrate-orders-to-d1.ts",
    "lint": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "db:generate": "pnpm --filter @p2p-me/db db:generate",
    "db:migrate": "pnpm --filter @p2p-me/db db:migrate"
  },
  "dependencies": {
    "@p2p-me/db": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "uuid": "^14.0.1",
    "viem": "^2.55.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0"
  }
}
